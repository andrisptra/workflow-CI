name: submission-MSML

python_env: conda.yaml

entry_points:
  main:
    parameters:
        train_path:
            type: str
            default: "asap2preprocessing/train_preprocessed.csv"
        test_path:
            type: str
            default: "asap2preprocessing/test_preprocessed.csv"
    command: "python modelling.py --train_path {train_path} --test_path {test_path}"
